@using Dota2Stat.Models
@inject IHttpClientFactory ClientFactory
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="row">
        <div class="col-md-2">
            <div class="main-card">
                <div style="color: white">
                    <h3 style="text-align: center">Поиск игрока</h3>
                    <p style="text-align: center">Введите Dota ID</p>
                </div>
                <div class="card-input">
                    <input class="form-control" placeholder="ID..." @bind="Id" />
                    <button class="btn btn-dota-red" @onclick="SearchProfile">Найти</button>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            @if (RootObject != null)
            {
                <div class="card-player">
                    <div class="d-flex align-items-center gap-3">
                        <img src="@RootObject.Profile.AvatarFull"
                             class="rounded"
                             style="width: 80px; height: 80px; object-fit: cover" />
                        <div class="flex-grow-1">
                            <h5 class="card-title mb-1">@RootObject.Profile.Name</h5>
                            <div class="card-text mb-2">
                                Ранг: @(RootObject.LeaderboardRank ?? 0)
                            </div>
                            <a href="@RootObject.Profile.ProfileUrl"
                               target="_blank"
                               class="btn btn-dota-red btn-sm w-100">Steam профиль</a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="main-card text-center text-white p-4">
                    <p>Введите ID игрока в панели слева</p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private int Id { get; set; }
    private RootObject? RootObject { get; set; }

    private async Task SearchProfile()
    {
        if (Id <= 0)
        {
            RootObject = null;
            return;
        }

        var client = ClientFactory.CreateClient();
        RootObject = await client.GetFromJsonAsync<RootObject>($"https://api.opendota.com/api/players/{Id}");
    }
}