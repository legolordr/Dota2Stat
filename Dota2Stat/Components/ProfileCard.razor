@using Dota2Stat.Models
@inject IHttpClientFactory ClientFactory
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="main-card">
                <div>
                    <h2 style="font: bold; text-align: center">Search players</h2>
                </div>
                <div class="card-input">
                    <input class="form-control" placeholder="ID..." @bind="Id"/>
                    <button class="btn btn-dota-red" @onclick="SearchProfile">Найти</button>
                    <span class="dota-red">По сравнению с моей кромешной тьмой, твоя душа просто сияет!</span>
                    <span class="dota-red-by">By Shadow Fiend</span>
                </div>
            </div>
        </div>

        <div class="col-md-9">
            @if (RootObject != null)
            {
                <div class="card-player p-4">
                    <div class="text-center mb-3">
                        <img src="@RootObject.Profile.AvatarFull"
                             class="rounded-circle"
                             style="width: 120px; height: 120px; object-fit: cover; border: 3px solid #ff3333;" />
                    </div>
                    <div class="text-center">
                        <h3 class="text-white mb-2">@RootObject.Profile.Name</h3>
                        <div class="rank-info mb-3">
                            <span class="badge bg-danger fs-6 p-2">Место в мире: @(RootObject.LeaderboardRank ?? 0)</span>
                        </div>
                        <a href="@RootObject.Profile.ProfileUrl"
                           target="_blank"
                           class="btn btn-dota-red w-100">Открыть Steam профиль</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private int? Id { get; set; } = null;
    private RootObject? RootObject { get; set; }

    private async Task SearchProfile()
    {
        if (Id <= 0)
        {
            RootObject = null;
            return;
        }

        var client = ClientFactory.CreateClient();
        RootObject = await client.GetFromJsonAsync<RootObject>($"https://api.opendota.com/api/players/{Id}");
    }
}