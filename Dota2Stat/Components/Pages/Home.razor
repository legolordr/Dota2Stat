@page "/"
@using Dota2Stat.Models
@inject IHttpClientFactory ClientFactory;
@rendermode InteractiveServer

<div class="container-fluid">
    @if (IsLoading)
    {
        <div class="text-center text-white p-5">
            <div class="spinner-border text-danger" role="status">
                <span class="visually-hidden">Загрузка...</span>
            </div>
            <p class="mt-3">Загрузка профиля игрока @Id</p>
        </div>
    }
    else
    {
        <div class="row m-2 justify-content-between">
            <div class="main-card col-2">
                <div>
                    <h2 style="font: bold; text-align: center">Поиск игроков</h2>
                </div>
                <div class="card-input">
                    <input class="form-control" placeholder="ID..." @bind="Id"/>
                    <button class="btn btn-dota-red" @onclick="GetProfile">Найти</button>
                    <span class="dota-red">По сравнению с моей кромешной тьмой твоя душа просто сияет!</span>
                    <span class="dota-red-by">By Shadow Fiend</span>
                </div>
            </div>
            <div class="col-4">
                @if (RootObject != null)
                {
                    <ProfileCard RootObject="RootObject" Winrate="Winrate"/>
                }
            </div>
            <div class="col-6">
                @if (RecentMatch != null && RecentMatch.Any())
                {
                    <div class="main-card p-3">
                        <h4 class="text-white mb-3">Недавние матчи</h4>
                        @foreach (var match in RecentMatch.Take(5))
                        {
                            <div class="match-item p-2 mb-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div style="min-width: 120px;">
                                        <span class="text-white">@GetHeroName(match.HeroId)</span>
                                    </div>
                                    <div>
                                        <span class="text-success">@match.Kills</span>
                                        <span class="text-white">/</span>
                                        <span class="text-danger">@match.Deaths</span>
                                        <span class="text-white">/</span>
                                        <span class="text-warning">@match.Assists</span>
                                    </div>
                                    <div>
                                        @if (match.RadiantWin)
                                        {
                                            <span class="text-success">✅ Победа</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger">❌ Поражение</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @if (HeroStats != null && HeroStats.Any())
        {
            <div class="row mt-4">
                <div class="col-12">
                    <div class="main-card p-3">
                        <h4 class="text-white mb-3">Самые успешные герои</h4>
                        <div class="row">
                            @foreach (var hero in HeroStats.OrderByDescending(h => h.Games).Take(8))
                            {
                                <div class="mb-2">
                                    <div class="hero-stat-item p-2">
                                        <div>
                                            <div class="text-white small">@GetHeroName(hero.HeroId)</div>
                                            <div class="text-success small">Winrate: @hero.WinRate% (@hero.Games игр)</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code
{
    private int? Id { get; set; }
    private bool IsLoading = false;

    private RootObject? RootObject { get; set; }
    private WL? Winrate { get; set; }
    private List<RecentMatch>? RecentMatch { get; set; }
    private Dictionary<long, string>? Heroes { get; set; }
    private List<HeroStats>? HeroStats { get; set; }

    private readonly string _baseUrl = "https://api.opendota.com/api";

    private async Task GetProfile()
    {
        if (Id <= 0 || Id == null)
        {
            RootObject = null;
            RecentMatch = null;
            HeroStats = null;
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        IsLoading = true;

        try
        {
            var client = ClientFactory.CreateClient();

            var profileTask = client.GetFromJsonAsync<RootObject>($"{_baseUrl}/players/{Id}");
            var winrateTask = client.GetFromJsonAsync<WL>($"{_baseUrl}/players/{Id}/wl");
            var matchesTask = client.GetFromJsonAsync<List<RecentMatch>>($"{_baseUrl}/players/{Id}/recentMatches");
            var heroStatsTask = client.GetFromJsonAsync<List<HeroStats>>($"{_baseUrl}/players/{Id}/heroes");
            var heroesTask = LoadHeroes();

            await Task.WhenAll(profileTask, winrateTask, matchesTask, heroesTask, heroStatsTask);

            RootObject = await profileTask;
            Winrate = await winrateTask;
            RecentMatch = await matchesTask;
            Heroes = await heroesTask;
            HeroStats = await heroStatsTask;
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<Dictionary<long, string>?> LoadHeroes()
    {
        var client = ClientFactory.CreateClient();
        var heroes = await client.GetFromJsonAsync<List<Hero>>($"{_baseUrl}/heroes");
        return heroes?.ToDictionary(h => h.Id, h => h.LocalizedName);
    }

    private string GetHeroName(long heroId)
    {
        if (Heroes != null && Heroes.TryGetValue(heroId, out var name))
        {
            return name;
        }
        return $"Hero {heroId}";
    }
}