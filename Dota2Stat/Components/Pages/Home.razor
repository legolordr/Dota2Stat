@page "/"
@using Dota2Stat.Models
@inject IHttpClientFactory ClientFactory;
@rendermode InteractiveServer

<div class="container-fluid">
    <div class="row m-2">
        <div class="main-card col-lg-2">
            <div>
                <h2 style="font: bold; text-align: center">Поиск игроков</h2>
            </div>
            <div class="card-input">
                <input class="form-control" placeholder="ID..." @bind="Id"/>
                <button class="btn btn-dota-red" @onclick="SearchProfile">Найти</button>
                <span class="dota-red">По сравнению с моей кромешной тьмой, твоя душа просто сияет!</span>
                <span class="dota-red-by">By Shadow Fiend</span>
            </div>
        </div>
        <div class="col-lg-4">
            @if (RootObject != null)
            {
                <ProfileCard RootObject="RootObject" Winrate="Winrate"/>
            }
        </div>
    </div>
</div>

@code
{
    private int? Id { get; set; }
    private RootObject? RootObject { get; set; }
    private WL Winrate { get; set; }
    private readonly string _baseUrl =  "https://api.opendota.com/api/players/";

    private async Task SearchProfile()
    {
        if (Id <= 0 | Id == null)
        {
            RootObject = null;
            return;
        }

        var client = ClientFactory.CreateClient();
        RootObject = await client.GetFromJsonAsync<RootObject>($"{_baseUrl}{Id}");
        await GetWrPlayer();
    }

    private async Task GetWrPlayer()
    {
        var client = ClientFactory.CreateClient();
        Winrate = await client.GetFromJsonAsync<WL>($"{_baseUrl}{Id}/wl");
    }
}
